generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  googleId    String   @unique @map("google_id") @db.VarChar(255)
  email       String   @unique @db.VarChar(255)
  displayName String   @map("display_name") @db.VarChar(100)
  avatarUrl   String?  @map("avatar_url") @db.Text
  fcmToken    String?  @map("fcm_token") @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  createdHouseholds Household[]       @relation("HouseholdCreatedBy")
  memberships       HouseholdMember[]
  budgets           Budget[]          @relation("BudgetCreatedBy")
  transactions      Transaction[]     @relation("TransactionCreatedBy")
  recurringRules    RecurringRule[]   @relation("RecurringCreatedBy")

  @@map("users")
}

model Household {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String   @db.VarChar(100)
  inviteCode      String   @unique @map("invite_code") @db.VarChar(20)
  defaultCurrency String   @default("IDR") @map("default_currency") @db.VarChar(3)
  createdById     String   @map("created_by") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  createdBy    User              @relation("HouseholdCreatedBy", fields: [createdById], references: [id])
  members      HouseholdMember[]
  budgets      Budget[]
  transactions Transaction[]
  recurring    RecurringRule[]
  summary      HouseholdSummary?

  @@map("households")
}

model HouseholdMember {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  householdId String   @map("household_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  role        String   @default("member") @db.VarChar(10)
  joinedAt    DateTime @default(now()) @map("joined_at") @db.Timestamptz()

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([householdId, userId])
  @@map("household_members")
}

model Category {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String  @db.VarChar(50)
  icon      String  @db.VarChar(50)
  color     String  @db.VarChar(7)
  type      String  @db.VarChar(10)
  isDefault Boolean @default(true) @map("is_default")
  sortOrder Int     @default(0) @map("sort_order")

  budgets Budget[]

  @@map("categories")
}

model Budget {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  householdId String   @map("household_id") @db.Uuid
  categoryId  String   @map("category_id") @db.Uuid
  month       Int
  year        Int
  amount      Decimal  @db.Decimal(15, 2)
  currency    String   @default("IDR") @db.VarChar(3)
  note        String?  @db.Text
  createdById String   @map("created_by") @db.Uuid
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  household    Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  category     Category      @relation(fields: [categoryId], references: [id])
  createdBy    User          @relation("BudgetCreatedBy", fields: [createdById], references: [id])
  transactions Transaction[]

  @@unique([householdId, categoryId, month, year])
  @@index([householdId, year, month], map: "idx_budgets_household_period")
  @@map("budgets")
}

// Transaction.categoryId has NO FK — can reference local custom categories
model Transaction {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  householdId  String   @map("household_id") @db.Uuid
  categoryId   String   @map("category_id") @db.Uuid
  budgetId     String?  @map("budget_id") @db.Uuid
  type         String   @db.VarChar(10)
  amount       Decimal  @db.Decimal(15, 2)
  currency     String   @default("IDR") @db.VarChar(3)
  exchangeRate Decimal  @default(1.0) @map("exchange_rate") @db.Decimal(15, 6)
  note         String?  @db.Text
  date         DateTime @db.Date
  recurringId  String?  @map("recurring_id") @db.Uuid
  createdById  String   @map("created_by") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  budget    Budget?   @relation(fields: [budgetId], references: [id], onDelete: SetNull)
  createdBy User      @relation("TransactionCreatedBy", fields: [createdById], references: [id])

  @@index([householdId, date(sort: Desc)], map: "idx_transactions_household_date")
  @@index([householdId, categoryId], map: "idx_transactions_category")
  @@index([budgetId], map: "idx_transactions_budget")
  @@map("transactions")
}

// RecurringRule.categoryId has NO FK — can reference local custom categories
model RecurringRule {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  householdId   String    @map("household_id") @db.Uuid
  categoryId    String    @map("category_id") @db.Uuid
  type          String    @db.VarChar(10)
  amount        Decimal   @db.Decimal(15, 2)
  currency      String    @default("IDR") @db.VarChar(3)
  note          String?   @db.Text
  frequency     String    @db.VarChar(10)
  startDate     DateTime  @map("start_date") @db.Date
  endDate       DateTime? @map("end_date") @db.Date
  isActive      Boolean   @default(true) @map("is_active")
  lastGenerated DateTime? @map("last_generated") @db.Date
  createdById   String    @map("created_by") @db.Uuid
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  createdBy User      @relation("RecurringCreatedBy", fields: [createdById], references: [id])

  @@index([isActive, lastGenerated], map: "idx_recurring_active")
  @@map("recurring_rules")
}

model HouseholdSummary {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  householdId          String    @unique @map("household_id") @db.Uuid
  totalIncome          Decimal   @default(0) @map("total_income") @db.Decimal(15, 2)
  totalExpense         Decimal   @default(0) @map("total_expense") @db.Decimal(15, 2)
  totalBalanceCarryOver Decimal  @default(0) @map("total_balance_carry_over") @db.Decimal(15, 2)
  lastCarryOverAt      DateTime? @map("last_carry_over_at") @db.Timestamptz()
  updatedAt            DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@map("household_summary_totals")
}

model News {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title     String   @db.VarChar(255)
  content   String   @db.Text
  imageUrl  String?  @map("image_url") @db.Text
  isPublished Boolean @default(true) @map("is_published")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  @@map("news")
}

model Banner {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  imageUrl  String   @map("image_url") @db.Text
  title     String?  @db.VarChar(255)
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  @@map("banners")
}
